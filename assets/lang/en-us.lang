option.ignoreEliminatedPlayers.name = Eliminee Skip
option.ignoreEliminatedPlayers.description = Players who are defeated will not play an animation when it's their turn.
option.allowPopping.name = Popping
option.allowPopping.description = Players non-fatally bursts when defeated.\nIf turned off, characters will be overinflated instead.\nTakes effect in the next game.
option.allowBellyGurgles.name = Borborygmi
option.allowBellyGurgles.description = Players play belly gurgle sounds on idle when inflated.
