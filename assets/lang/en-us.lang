option.allowBellyCreaks.description = Players play balloon overstretching sounds on idle when inflated.
option.enableFullscreen.name = Fullscreen
option.enableFullscreen.description = Self-explanatory, but are you that deprived?
option.enableForceAliasing.name = Forced Alising
option.enableForceAliasing.description = Disables antialiasing from all sprites even when enabled. Improves performance, but may make some graphics look jagged.
option.alwaysPlayMainMenuAnims.name = Entertaining Main Menu
option.alwaysPlayMainMenuAnims.description = Always play startup animations in the Main Menu.
option.showMusicToast.name = Music Toast
option.showMusicToast.description = A notification containing the current background music name and its author will be shown whenever a music track is played.
option.enableLetterbox.name = Letterboxing
option.enableLetterbox.description = Show black bars on top and bottom sides of the screen during player animations and cutscenes.
option.useClassicMusic.name = Classic Music
option.useClassicMusic.description = The game uses music in the original game instead of new music.
option.musicVolume.name = Music Volume
option.musicVolume.description = The volume percentage of background music.
option.gameSoundVolume.name = Game Sound Volume
option.gameSoundVolume.description = The volume percentage of game sound effects.
option.uiSoundVolume.name = UI Sound Volume
option.uiSoundVolume.description = The volume percentage of UI sound effects.
option.enablePhotosensitiveMode.name = Photosensitive Mode
option.enablePhotosensitiveMode.description = Dampen screen flashes and other flashing effects.\nStrongly recommended for people with photosensitive epilepsy.
option.cameraEffectIntensity.name = Camera Intensity
option.cameraEffectIntensity.description = How strong screen shaking and other disorienting effects should be.
option.useBuiltInCursor.name = Built-In Cursor
option.useBuiltInCursor.description = Uses the custom in-game cursor instead of the default system mouse cursor.
option.hideCursor.name = Hide Cursor
option.hideCursor.description = Hides the mouse cursor entirely.\nCursor can be shown again by pressing [G] at any time.
option.playCursorSounds.name = Cursor Sounds
option.playCursorSounds.description = Plays a click sound whenever the mouse cursor clicks something.
option.maxFramerate.name = Maximum Framerate
option.maxFramerate.description = How many screen refreshes and game updates should the game do in one second.
option.pauseOnUnfocus.name = Unfocus Pausing
option.pauseOnUnfocus.description = Automatically pauses the game when out of focus.
option.cacheOnGPU.name = VRAM Caching
option.cacheOnGPU.description = Allows the GPU to be used for storing textures using VRAM for lower RAM usage.\nMay not work correctly with lower-end graphics cards.
option.enableDebugKeybinds.name = Debug Keybinds
option.enableDebugKeybinds.description = Enable debug keybinds on PC. (If you're on mobile, too bad lmao)
