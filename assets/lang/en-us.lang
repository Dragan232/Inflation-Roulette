option.showDebugText.description = Displays debug information on the top-left corner of the screen.
option.showFramerateOnDebugText.name = Framerate
option.showFramerateOnDebugText.description = Displays the current framerate on the Debug Text.
option.showMemoryUsageOnDebugText.name = Memory Usage
option.showMemoryUsageOnDebugText.description = Displays the current amount of memory used on the Debug Text.
option.showCurrentStateOnDebugText.name = Current State
option.showCurrentStateOnDebugText.description = Displays the current menu being navigated on the Debug Text.

